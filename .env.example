# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
AUTHORIZED_CHAT_ID=123456789

# Vault
VAULT_PATH=./vault

# AI (provider: openai | anthropic)
AI_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
CONTENT_MODEL=gpt-4.1
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20241022

# Content generation (/generate threads)
# how many topics to suggest when /generate has no topic
CONTENT_TOPIC_COUNT=10
# notes randomly sampled per suggestion call (variety, avoids repeating topics)
CONTENT_TOPIC_SAMPLE=25

# /ask tuning (whole-diary Q&A)
# minimal | low | medium | high (reasoning models only; lower = faster)
ASK_MODEL=gpt-5-mini
ASK_REASONING_EFFORT=low
# second fact-check pass; true = safer but ~doubles latency
ASK_VERIFY=false
# full-text budget; overflow notes degrade to one-line digests
ASK_CONTEXT_BUDGET_CHARS=200000
# per-note cap so one long note can't eat the budget
ASK_NOTE_MAX_CHARS=4000
# how many notes to list as "Based on:" sources
ASK_SOURCE_LIMIT=10
# how many notes to rank per query (whole corpus at current scale)
ASK_WIDE_POOL=500

# Transcription (OpenAI Whisper)
OPENAI_WHISPER_MODEL=whisper-1

# CouchDB (LiveSync)
COUCHDB_URL=http://couchdb:5984
COUCHDB_USER=admin
COUCHDB_PASSWORD=changeme
COUCHDB_DB_NAME=obsidian-livesync
